# Production Environment Variables Template for Railway

# ============================================
# Backend Service Environment Variables
# ============================================

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=anthropic/claude-3.5-sonnet
EMBEDDING_MODEL=openai/text-embedding-3-small

# Database Connection
# Railway will auto-populate this when you link the PostgreSQL service
DATABASE_URL=${{Postgres.DATABASE_URL}}

# CORS Configuration
# Add your Railway frontend URL after deployment
ALLOWED_ORIGINS=https://your-frontend-url.railway.app

# Upload Configuration
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=/tmp/regulations

# Optional: For production logging
LOG_LEVEL=INFO

# ============================================
# Frontend Service Environment Variables
# ============================================

# API URL - Replace with your Railway backend URL
NEXT_PUBLIC_API_URL=https://your-backend-url.railway.app

# ============================================
# PostgreSQL Service
# ============================================
# Railway automatically creates these:
# - PGHOST
# - PGPORT
# - PGUSER
# - PGPASSWORD
# - PGDATABASE
# - DATABASE_URL

# ============================================
# POST-DEPLOYMENT CHECKLIST
# ============================================
# 1. Replace 'your_openrouter_api_key_here' with actual key
# 2. Update 'your-frontend-url.railway.app' with deployed frontend URL
# 3. Update 'your-backend-url.railway.app' with deployed backend URL
# 4. Ensure DATABASE_URL is linked to PostgreSQL service
# 5. Run schema.sql in PostgreSQL Query tab to initialize database
# 6. Redeploy services after environment variable changes
