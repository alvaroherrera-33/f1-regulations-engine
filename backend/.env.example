# Backend environment variables — local development
# Copy to backend/.env and fill in your values.
# See root .env.example for the complete reference.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/f1_regs

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=openai/gpt-oss-120b

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Admin key (protects upload, sync, admin endpoints)
ADMIN_API_KEY=your_admin_api_key_here

# File upload
UPLOAD_DIR=data/regulations
MAX_UPLOAD_SIZE=52428800
