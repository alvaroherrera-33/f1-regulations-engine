# F1 Regulations Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file (it is in .gitignore).

# ── Database (required for docker-compose) ──────────────────────────────────
# Password for the bundled Postgres container. Any value works locally.
POSTGRES_PASSWORD=postgres

# PostgreSQL connection string — only needed when running the backend WITHOUT
# docker-compose (compose builds this automatically from POSTGRES_PASSWORD).
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/f1_regs
# Supabase (production) — use the Session Pooler URL, not the direct connection:
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?ssl=require

# ── LLM provider (OpenAI-compatible) ────────────────────────────────────────
# Needed only to GENERATE chat answers. Retrieval, the demo and Compare work
# without it (embeddings run locally with a vendored ONNX model — no key/GPU).
#
# Option A — OpenRouter (hosted, default):
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=openai/gpt-oss-120b
LLM_BASE_URL=https://openrouter.ai/api/v1
#
# Option B — fully local & free with Ollama (no API key):
#   docker compose --profile ollama up
#   docker compose exec ollama ollama pull llama3.1
# then set:
# OPENROUTER_API_KEY=
# LLM_MODEL=llama3.1
# LLM_BASE_URL=http://ollama:11434/v1

# ── Other ───────────────────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Admin API key — required to access /api/upload, /api/admin/*, POST /api/sync/check
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=your_admin_api_key_here

# Structural pipeline (TOC-aware parsing + subtree retrieval). Optional; 0 LLM cost.
STRUCTURAL_PARSER=false

# File upload settings
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=data/regulations
